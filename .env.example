ENVIRONMENT=development
DATABASE_URL=postgresql+psycopg://scout:scout@localhost:5432/scouts_edge
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
FOOTBALL_DATA_PROVIDER=mock
API_FOOTBALL_KEY=
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Production notes:
# - Frontend: deploy /frontend to Vercel and set NEXT_PUBLIC_API_BASE_URL to the hosted FastAPI URL.
# - Backend: deploy /backend as a Docker-compatible FastAPI service on Render, Railway, Fly.io, or a VPS.
# - Database: set DATABASE_URL to Neon Postgres or Supabase Postgres.
# - CORS_ORIGINS should include the Vercel dashboard domain.
