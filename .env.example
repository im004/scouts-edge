ENVIRONMENT=development
DATABASE_URL=postgresql+psycopg://<user>:<password>@localhost:5432/scouts_edge
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001
FOOTBALL_DATA_PROVIDER=mock
API_FOOTBALL_KEY=
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
BACKEND_INTERNAL_URL=http://backend:8000

# Production notes:
# - Frontend: deployed on Vercel.
# - Backend: deployed on Render at https://scouts-edge.onrender.com.
# - Database: hosted on Neon Postgres.
# - Vercel: NEXT_PUBLIC_API_BASE_URL=https://scouts-edge.onrender.com.
# - Render: DATABASE_URL=<Neon connection string>.
# - Render: CORS_ORIGINS=https://scouts-edge.vercel.app,http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001.
